<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- The server is user-configurable in Settings, so cleartext has to be open
         broadly (LAN IPs, mDNS, etc.). The trade-off is intentional for a
         self-hosted personal app. -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
